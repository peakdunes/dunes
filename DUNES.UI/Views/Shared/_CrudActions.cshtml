@model DUNES.UI.Models.CrudActionsModel
@using Microsoft.AspNetCore.Routing
@using System.Text.RegularExpressions

<style>
    .btn-outline-danger:hover i,
    .btn-outline-primary:hover i,
    .btn-outline-warning:hover i,
    .btn-outline-secondary:hover i,
    .btn-primary:hover i {
        color: #fff !important;
    }
</style>

@functions {
    private RouteValueDictionary BuildRouteValues(
        string? template,
        Dictionary<string, object?>? sourceValues)
    {
        var values = new RouteValueDictionary();

        if (string.IsNullOrWhiteSpace(template))
            return values;

        var pairs = template.Split('&', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        foreach (var pair in pairs)
        {
            var parts = pair.Split('=', 2, StringSplitOptions.TrimEntries);

            if (parts.Length != 2)
                continue;

            var routeKey = parts[0];
            var rawValue = parts[1];

            if (string.IsNullOrWhiteSpace(routeKey))
                continue;

            object? resolvedValue = ResolveTemplateValue(rawValue, sourceValues);

            if (resolvedValue != null)
            {
                values[routeKey] = resolvedValue;
            }
        }

        return values;
    }

    private object? ResolveTemplateValue(
        string rawValue,
        Dictionary<string, object?>? sourceValues)
    {
        if (string.IsNullOrWhiteSpace(rawValue))
            return null;

        var match = Regex.Match(rawValue, @"^\{(?<key>[A-Za-z0-9_]+)\}$");

        if (!match.Success)
        {
            // Static literal value
            return rawValue;
        }

        var sourceKey = match.Groups["key"].Value;

        if (sourceValues == null || !sourceValues.TryGetValue(sourceKey, out var value))
        {
            return null;
        }

        return value;
    }
}

@{
    var controller = string.IsNullOrWhiteSpace(Model.Controller) ? null : Model.Controller;
}

@if (Model.Actions != null && Model.Actions.Any())
{
    foreach (var action in Model.Actions.OrderBy(x => x.ButtonOrder))
    {
        var routeValues = BuildRouteValues(action.RouteParamsTemplate, Model.RouteSourceValues);

        var url = Url.Action(
            action.MvcActionName,
            controller,
            routeValues
        );

        if (!string.IsNullOrWhiteSpace(url))
        {
            <a href="@url"
               class="@($"{action.TextCss} {action.ButtonCss}")"
               title="@action.ButtonText"
               data-requires-confirmation="@(action.RequiresConfirmation ? "true" : "false")"
               data-confirmation-message="@action.ConfirmationMessage">
                <i class="@action.IconCss"></i>
            </a>
        }
    }
}