@model DUNES.Shared.WiewModels.Auth.ChangePasswordVM

@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_LayoutAuthSimple.cshtml";
}

<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center">
    <div class="card shadow-sm border-0" style="width: 100%; max-width: 560px; border-radius: 14px;">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <h2 class="mb-2">Change Password</h2>
                <p class="text-muted mb-0">
                    You must change your password before continuing to use the system.
                </p>
            </div>

            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="CurrentPassword" class="form-label fw-semibold"></label>
                    <input asp-for="CurrentPassword" class="form-control" type="password" />
                    <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                    <input asp-for="NewPassword" class="form-control" type="password" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">
                        Change Password
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}