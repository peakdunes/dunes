@using DUNES.UI.Helpers
@inject IUserPermissionSessionHelper PermissionSession
@model List<DUNES.Shared.DTOs.Auth.UserReadDTO>

@{
    ViewData["Title"] = "Users";
}

@if (PermissionSession.HasPermission("Auth.User.Create"))
{
    <p>
        <a type="button" class="btn btn-outline-primary" asp-action="Create">Create New</a>
    </p>
}

<div class="row">
    <table id="tablelist" class="table table-bordered table-striped table-hover table-sm align-middle w-100" style="white-space: nowrap; font-size:medium">

        <thead class="table-light">
            <tr>
                <th>Actions</th>
                <th>Photo</th>
                <th>UserName</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Active</th>
                <th>Must Change Password</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>
                       
                </td>

                    <td class="text-center">
                        <partial name="_UserProfilePhoto"
                                 model='new DUNES.UI.Models.Auth.UserPhotoViewModel
                             {
                                 UserId = user.Id,
                                 Variant = "thumb",
                                 AltText = user.FullName
                             }' />
                </td>

                    <td>@user.UserName</td>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>@user.RoleName</td>
                    <td>@(user.IsActive ? "Yes" : "No")</td>
                    <td>@(user.MustChangePassword ? "Yes" : "No")</td>
                </tr>
                        }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(document).ready(function(){
            $('#tablelist').DataTable({
                scrollX: true,
            });
        })
    </script>
}