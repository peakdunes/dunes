@model DUNES.Shared.DTOs.Auth.ResetPasswordDTO

@{
    ViewData["Title"] = "Reset Password";
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Reset Password</h2>
        <div class="text-muted">Assign a new password to the selected user.</div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form asp-action="ResetPassword" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input asp-for="UserId" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-4">
                    <div class="col-lg-8">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Full Name</label>
                                <input class="form-control" value="@ViewBag.UserName" readonly />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Email</label>
                                <input class="form-control" value="@ViewBag.UserEmail" readonly />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                                <input asp-for="NewPassword" type="password" class="form-control" placeholder="Enter new password" />
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="d-flex justify-content-center justify-content-lg-end">
                            <partial name="_UserProfilePhoto"
                                     model='new DUNES.UI.Models.Auth.UserPhotoViewModel
                                     {
                                         UserId = Model.UserId,
                                         Variant = "card",
                                         AltText = ViewBag.UserName ?? "User Photo"
                                     }' />
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Back
                    </a>
                    <button type="submit" class="btn btn-warning">
                        <i class="fas fa-key me-1"></i> Reset Password
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}