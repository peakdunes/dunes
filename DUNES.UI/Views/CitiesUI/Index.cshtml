@using DUNES.UI.Helpers
@inject IUserPermissionSessionHelper PermissionSession
@model IEnumerable<DUNES.Shared.DTOs.WMS.WMSCitiesReadDTO>


@{
    var rowActions = ViewBag.RowActions as List<CrudActionItemModel> ?? new List<CrudActionItemModel>();
    var toolbarActions = ViewBag.ToolbarActions as List<CrudActionItemModel> ?? new List<CrudActionItemModel>();
}
@if (toolbarActions.Any())
{
    <div class="row g-2 mb-3">
        @foreach (var action in toolbarActions.OrderBy(x => x.ButtonOrder).Take(6))
        {
            <div class="col-12 col-sm-6 col-md-2">
                <a asp-action="@action.MvcActionName"
                   class="@($"{action.ButtonCss} {action.TextCss} w-100 d-inline-flex align-items-center justify-content-center")"
                   title="@action.ButtonText">
                    @if (!string.IsNullOrWhiteSpace(action.IconCss))
                    {
                        <i class="@action.IconCss"></i>
                    }
                    @if (!string.IsNullOrWhiteSpace(action.ButtonText))
                    {
                        <span class="ms-1">@action.ButtonText</span>
                    }
                </a>
            </div>
        }
    </div>
}

<div class="row">
    @using (Html.BeginForm("Index", "CitiesUI", FormMethod.Get))
    {

        <div class="col-md-4">
            <div class="form-group">
                <label class="control-label">Country </label>

                @Html.DropDownList(
                "countryId",
                (SelectList)ViewBag.ListCountries,
                "-- Select Country --",
                new {
                    @class = "form-control",
                    onchange = "this.form.submit();"
            })

            </div>
        </div>
    }
</div>
<div class="row">
    <table id="tablelist" class="table table-bordered table-striped table-hover table-sm align-middle w-100" style="white-space: nowrap; font-size:medium">

    <thead>
        <tr>
            <th>Actions</th>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Idcountry)
            </th>
             <th>
                @Html.DisplayNameFor(model => model.IdcountryNavigation.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Idstate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IdstateNavigation.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Active)
            </th>
            
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
              <td>
               <partial name="_CrudActions"
                 model="@(new DUNES.UI.Models.CrudActionsModel 
                     { 
                         RouteSourceValues = new Dictionary<string, object?>
                         {
                             ["Id"] = item.Id,
                         },Controller = "CitiesUI", Actions = rowActions 
                     })" />
                       
            <td>
                @Html.DisplayFor(modelItem => item.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Idcountry)
            </td>
               <td>
                @Html.DisplayFor(modelItem => item.IdcountryNavigation.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Idstate)
            </td>
              <td>
                @Html.DisplayFor(modelItem => item.IdstateNavigation.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Active)
            </td>
           
        </tr>
}
    </tbody>
</table>
</div>

@section Scripts {




    <script>


        $(document).ready(function(){

                     $('#tablelist').DataTable
                   ({

                     scrollX: true,

                   });

        })


    </script>
}