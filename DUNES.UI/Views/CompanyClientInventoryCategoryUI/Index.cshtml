@model IEnumerable<DUNES.Shared.DTOs.WMS.WMSCompanyClientInventoryCategoryReadDTO>

@{
    ViewData["Title"] = "Index";
}


<p>
    <a type="button" class="btn btn-outline-primary" asp-action="Create">Create New</a>
</p>
<div class="row">
    <table id="tablelist" class="table table-bordered table-striped table-hover table-sm align-middle w-100" style="white-space: nowrap; font-size:medium">

        <thead>
            <tr>
                <th>Actions</th>
               @*  <th style="display:none">
                    @Html.DisplayNameFor(model => model.Id)
                </th> *@
                <th>
                    @Html.DisplayNameFor(model => model.InventoryCategoryId)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.InventoryCategoryName)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.IsActive)
                </th>

            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <partial name="_CrudActions"
                                 model="@(new DUNES.UI.Models.CrudActionsModel { RouteId = item.Id.ToString(), Controller = "CompanyClientInventoryCategoryUI" })" />
                    </td>
                  @*   <td style="display:none">
                        @Html.DisplayFor(modelItem => item.Id)
                    </td> *@
                    <td>
                        @Html.DisplayFor(modelItem => item.InventoryCategoryId)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.InventoryCategoryName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.IsActive)
                    </td>
            
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {




    <script>


        $(document).ready(function(){

                     $('#tablelist').DataTable
                   ({

                     scrollX: true,

                   });

        })


    </script>
}