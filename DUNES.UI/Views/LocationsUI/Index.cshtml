@using DUNES.UI.Helpers
@using DUNES.UI.Models
@model IEnumerable<DUNES.Shared.DTOs.WMS.WMSLocationsReadDTO>

@inject IUserPermissionSessionHelper PermissionSession

@{
    ViewData["Title"] = "Index";

    var rowActions = ViewBag.RowActions as List<CrudActionItemModel> ?? new List<CrudActionItemModel>();
    var toolbarActions = ViewBag.ToolbarActions as List<CrudActionItemModel> ?? new List<CrudActionItemModel>();
}

@if (toolbarActions.Any())
{
    <div class="row g-2 mb-3">
        @foreach (var action in toolbarActions.OrderBy(x => x.ButtonOrder).Take(6))
        {
            <div class="col-12 col-sm-6 col-md-2">
                <a asp-action="@action.MvcActionName"
                   class="@($"{action.ButtonCss} {action.TextCss} w-100 d-inline-flex align-items-center justify-content-center")"
                   title="@action.ButtonText">
                    @if (!string.IsNullOrWhiteSpace(action.IconCss))
                    {
                        <i class="@action.IconCss"></i>
                    }
                    @if (!string.IsNullOrWhiteSpace(action.ButtonText))
                    {
                        <span class="ms-1">@action.ButtonText</span>
                    }
                </a>
            </div>
        }
    </div>
}
<table id="tablelist" class="table table-bordered table-striped table-hover table-sm align-middle w-100" style="white-space: nowrap; font-size:medium">
    <thead>
        <tr>
            <th>Actions</th>
            <th>@Html.DisplayNameFor(model => model.Id)</th>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Idcompany)</th>
            <th>@Html.DisplayNameFor(model => model.companyname)</th>
            <th>@Html.DisplayNameFor(model => model.Idcity)</th>
            <th>@Html.DisplayNameFor(model => model.cityname)</th>
            <th>@Html.DisplayNameFor(model => model.Address)</th>
            <th>@Html.DisplayNameFor(model => model.Zipcode)</th>
            <th>@Html.DisplayNameFor(model => model.Phone)</th>
            <th>@Html.DisplayNameFor(model => model.Active)</th>
            <th>@Html.DisplayNameFor(model => model.Idcountry)</th>
            <th>@Html.DisplayNameFor(model => model.countryname)</th>
            <th>@Html.DisplayNameFor(model => model.Idstate)</th>
            <th>@Html.DisplayNameFor(model => model.statename)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <partial name="_CrudActions"
                             model="@(new CrudActionsModel
                             {
                                 RouteId = item.Id.ToString(),
                                 Controller = "LocationsUI",
                                 Actions = rowActions
                             })" />
            </td>
            <td>@Html.DisplayFor(modelItem => item.Id)</td>
            <td>@Html.DisplayFor(modelItem => item.Name)</td>
            <td>@Html.DisplayFor(modelItem => item.Idcompany)</td>
            <td>@Html.DisplayFor(modelItem => item.companyname)</td>
            <td>@Html.DisplayFor(modelItem => item.Idcity)</td>
            <td>@Html.DisplayFor(modelItem => item.cityname)</td>
            <td>@Html.DisplayFor(modelItem => item.Address)</td>
            <td>@Html.DisplayFor(modelItem => item.Zipcode)</td>
            <td>@Html.DisplayFor(modelItem => item.Phone)</td>
            <td>@Html.DisplayFor(modelItem => item.Active)</td>
            <td>@Html.DisplayFor(modelItem => item.Idcountry)</td>
            <td>@Html.DisplayFor(modelItem => item.countryname)</td>
            <td>@Html.DisplayFor(modelItem => item.Idstate)</td>
            <td>@Html.DisplayFor(modelItem => item.statename)</td>
        </tr>
                }
    </tbody>
</table>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablelist').DataTable({
                scrollX: true
            });
        });
    </script>
}