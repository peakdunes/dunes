@model DUNES.UI.Models.Auth.RolePermissionsMatrixPageVM

@{
    ViewData["Title"] = "Role Permissions Matrix";
}

<style>
    .matrix-wrapper {
        overflow-x: auto;
        overflow-y: auto;
        max-height: 65vh;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
    }

    .matrix-table th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: #f8f9fa;
        white-space: nowrap;
    }

    .matrix-table td {
        vertical-align: middle;
        white-space: nowrap;
    }

    .matrix-sticky-col {
        position: sticky;
        left: 0;
        z-index: 1;
        background: #fff;
    }

    .matrix-sticky-col-2 {
        position: sticky;
        left: 140px;
        z-index: 1;
        background: #fff;
    }

    .matrix-table thead .matrix-sticky-col,
    .matrix-table thead .matrix-sticky-col-2 {
        z-index: 3;
        background: #f8f9fa;
    }

    .matrix-group-col {
        min-width: 140px;
        width: 140px;
    }

    .matrix-module-col {
        min-width: 240px;
        width: 240px;
    }

    .matrix-action-col {
        min-width: 110px;
        text-align: center;
    }
</style>

<div class="container py-4">
  
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <form asp-action="Index" method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-lg-5 col-md-6">
                        <label asp-for="RoleId" class="form-label fw-semibold">Role</label>
                        <select asp-for="RoleId" asp-items="Model.Roles" class="form-select">
                            <option value="">-- Select role --</option>
                        </select>
                    </div>

                    <div class="col-lg-2 col-md-3">
                        <button type="submit" class="btn btn-outline-primary w-100">
                            <i class="fas fa-search me-1"></i> Load
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.RoleId))
    {
        <div class="card shadow-sm border-0">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <div>
                    <span class="fw-bold">Permissions Matrix</span>
                    <div class="small text-muted">Modules as rows, actions as dynamic columns</div>
                </div>

                <button type="button" class="btn btn-outline-primary" id="saveMatrixBtnTop">
                    <i class="fas fa-save me-1"></i> Save Changes
                </button>
            </div>

            <div class="card-body">
                @if (Model.Rows != null && Model.Rows.Any())
                {
                    <form asp-action="SaveMatrix" method="post" id="matrixForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="RoleId" value="@Model.RoleId" />

                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Search module</label>
                                <input type="text" id="matrixSearch" class="form-control" placeholder="Search module..." />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label fw-semibold">Group</label>
                                <select id="matrixGroupFilter" class="form-select">
                                    <option value="">All groups</option>
                                    @foreach (var group in Model.Rows.Select(x => x.Group).Distinct().OrderBy(x => x))
                                    {
                                        <option value="@group">@group</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-2 d-flex align-items-end">
                                <button type="button" class="btn btn-outline-secondary w-100" id="clearMatrixFiltersBtn">
                                    Clear
                                </button>
                            </div>
                        </div>

                        <div class="matrix-wrapper">
                            <table class="table table-bordered table-hover align-middle mb-0 matrix-table" id="matrixTable">
                                <thead class="table-light">
                                    <tr>
                                        <th class="matrix-sticky-col matrix-group-col">Group</th>
                                        <th class="matrix-sticky-col-2 matrix-module-col">Module</th>

                                        @foreach (var action in Model.Actions)
                                        {
                                            <th class="matrix-action-col text-center">
                                                @action
                                            </th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in Model.Rows)
                                    {
                                        <tr data-group="@row.Group" data-module="@row.Module">
                                            <td class="matrix-sticky-col matrix-group-col">@row.Group</td>
                                            <td class="matrix-sticky-col-2 matrix-module-col">@row.Module</td>

                                            @foreach (var action in Model.Actions)
                                            {
                                                var cell = row.Cells[action];

                                                <td class="text-center matrix-action-col">
                                                    @if (!cell.Exists)
                                                    {
                                                        <span class="text-muted">—</span>
                                                    }
                                                    else
                                                    {
                                                        <input type="checkbox"
                                                               name="PermissionIds"
                                                               value="@cell.PermissionId"
                                                               class="matrix-check"
                                                               @(cell.Assigned ? "checked" : null) />
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex justify-content-end mt-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i> Save Changes
                            </button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="text-muted">No permissions available for this role.</div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const matrixSearch = document.getElementById('matrixSearch');
            const matrixGroupFilter = document.getElementById('matrixGroupFilter');
            const clearMatrixFiltersBtn = document.getElementById('clearMatrixFiltersBtn');
            const matrixForm = document.getElementById('matrixForm');
            const saveMatrixBtnTop = document.getElementById('saveMatrixBtnTop');

            function filterMatrixRows() {
                const search = (matrixSearch?.value || '').toLowerCase();
                const group = (matrixGroupFilter?.value || '').toLowerCase();

                document.querySelectorAll('#matrixTable tbody tr').forEach(row => {
                    const module = (row.getAttribute('data-module') || '').toLowerCase();
                    const rowGroup = (row.getAttribute('data-group') || '').toLowerCase();

                    const matchSearch = !search || module.includes(search);
                    const matchGroup = !group || rowGroup === group;

                    row.style.display = (matchSearch && matchGroup) ? '' : 'none';
                });
            }

            matrixSearch?.addEventListener('input', filterMatrixRows);
            matrixGroupFilter?.addEventListener('change', filterMatrixRows);

            clearMatrixFiltersBtn?.addEventListener('click', function () {
                if (matrixSearch) matrixSearch.value = '';
                if (matrixGroupFilter) matrixGroupFilter.value = '';
                filterMatrixRows();
            });

            saveMatrixBtnTop?.addEventListener('click', function () {
                matrixForm?.requestSubmit();
            });

            matrixForm?.addEventListener('submit', function (e) {
                const confirmed = confirm('Are you sure you want to save the current permission matrix for this role?');
                if (!confirmed) {
                    e.preventDefault();
                }
            });
        });
    </script>
}