@using DUNES.UI.Helpers
@inject IUserPermissionSessionHelper PermissionSession
@model IEnumerable<DUNES.Shared.DTOs.WMS.WMSCompaniesContractReadDTO>

@{
    ViewData["Title"] = "Index";
}

@{
    var rowActions = ViewBag.RowActions as List<CrudActionItemModel> ?? new List<CrudActionItemModel>();
    var toolbarActions = ViewBag.ToolbarActions as List<CrudActionItemModel> ?? new List<CrudActionItemModel>();
}

@if (toolbarActions.Any())
{
    <div class="row g-2 mb-3">
        @foreach (var action in toolbarActions.OrderBy(x => x.ButtonOrder).Take(6))
        {
            <div class="col-12 col-sm-6 col-md-2">
                <a asp-action="@action.MvcActionName"
                   class="@($"{action.ButtonCss} {action.TextCss} w-100 d-inline-flex align-items-center justify-content-center")"
                   title="@action.ButtonText">
                    @if (!string.IsNullOrWhiteSpace(action.IconCss))
                    {
                        <i class="@action.IconCss"></i>
                    }
                    @if (!string.IsNullOrWhiteSpace(action.ButtonText))
                    {
                        <span class="ms-1">@action.ButtonText</span>
                    }
                </a>
            </div>
        }
    </div>
}


<div class="row">
    @using (Html.BeginForm("Index", "CompaniesClientContractUI", FormMethod.Get))
    {

        <div class="col-md-4">
            <div class="form-group">
                <label class="control-label">Client Companies</label>

                @Html.DropDownList(
                "companyclientid",
                (SelectList)ViewBag.companiesclient,
                "Select Company Client",
                new {
                    @class = "form-control",
                    onchange = "this.form.submit();"
            })

            </div>
        </div>
    }
</div>



<table id="tablelist" class="table table-bordered table-striped table-hover table-sm align-middle w-100" style="white-space: nowrap; font-size:medium">
    <thead>
        <tr>
            <th>Actions</th>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CompanyId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.companyname)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CompanyClientId)
            </th>

            <th>
                @Html.DisplayNameFor(model => model.companyclientname)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StartDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EndDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsActive)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ContractCode)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ContactName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ContactEmail)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ContactPhone)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Notes)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ItemCatalogMode)
            </th>
           
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        
                    <partial name="_CrudActions"
                             model="@(new DUNES.UI.Models.CrudActionsModel 
                                 { RouteId = item.Id.ToString(), Controller = "CompaniesContract", Actions = rowActions })" />
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Id)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.CompanyId)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.companyname)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.CompanyClientId)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.companyclientname)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.StartDate)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.EndDate)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.IsActive)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.ContractCode)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.ContactName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.ContactEmail)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.ContactPhone)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Notes)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.ItemCatalogMode)
                    </td>
                    
                </tr>
            }

        }
    </tbody>
</table>
@section Scripts {




    <script>


        $(document).ready(function(){

                     $('#tablelist').DataTable
                   ({

                     scrollX: true,

                   });

        })


    </script>
}