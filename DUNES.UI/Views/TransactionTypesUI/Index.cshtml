@model IEnumerable<DUNES.Shared.DTOs.WMS.WMSTransactiontypesReadDTO>

@{
    ViewData["Title"] = "Index";
}


<p>
    <a type="button" class="btn btn-outline-primary" asp-action="Create">Create New</a>
</p>
<div class="row">
    <table id="tablelist" class="table table-bordered table-striped table-hover table-sm align-middle w-100"
           style="white-space: nowrap; font-size: medium">
        <thead>
            <tr>
                <th>Actions</th>
                <th>
                    @Html.DisplayNameFor(model => model.Id)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Name)
                </th>
              
                <th>
                    @Html.DisplayNameFor(model => model.Isinput)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Isoutput)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Active)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Match)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.companyId)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.companyname)
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <partial name="_CrudActions"
                                 model="@(new DUNES.UI.Models.CrudActionsModel { RouteId = item.Id.ToString(), Controller = "TransactionTypesUI" })" />
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Id)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                 
                    <td>
                        @Html.DisplayFor(modelItem => item.Isinput)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Isoutput)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Active)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Match)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.companyId)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.companyname)
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablelist').DataTable({
                scrollX: true
            });
        });
    </script>
}