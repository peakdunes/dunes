@model IEnumerable<DUNES.Shared.DTOs.WMS.WMSInventorycategoriesReadDTO>

@{
    ViewData["Title"] = "Inventory Categories List";
}

<p>
    <a type="button" class="btn btn-outline-primary" asp-action="Create">Create New</a>
</p>

<div class="row">
    <table id="tablelist" class="table table-bordered table-striped table-hover table-sm align-middle w-100"
           style="white-space: nowrap; font-size: medium">
        <thead>
            <tr>
                <th>Actions</th>
                <th>@Html.DisplayNameFor(model => model.First().Id)</th>
                <th>@Html.DisplayNameFor(model => model.First().Name)</th>
                <th>@Html.DisplayNameFor(model => model.First().Observations)</th>
                <th>@Html.DisplayNameFor(model => model.First().CycleCountDays)</th>
                <th>@Html.DisplayNameFor(model => model.First().ErrorTolerance)</th>
                <th>@Html.DisplayNameFor(model => model.First().Active)</th>
                <th>@Html.DisplayNameFor(model => model.First().CompanyId)</th>
                <th>@Html.DisplayNameFor(model => model.First().CompanyName)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model ?? Enumerable.Empty<DUNES.Shared.DTOs.WMS.WMSInventorycategoriesReadDTO>())
            {
                <tr>
                    <td>
                        <partial name="_CrudActions"
                                 model="@(new DUNES.UI.Models.CrudActionsModel { RouteId = item.Id.ToString(), Controller = "InventoryCategoriesUI" })" />
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.Id)</td>
                    <td>@Html.DisplayFor(modelItem => item.Name)</td>
                    <td>@Html.DisplayFor(modelItem => item.Observations)</td>
                    <td>@Html.DisplayFor(modelItem => item.CycleCountDays)</td>
                    <td>@Html.DisplayFor(modelItem => item.ErrorTolerance)</td>
                    <td>@Html.DisplayFor(modelItem => item.Active)</td>
                    <td>@Html.DisplayFor(modelItem => item.CompanyId)</td>
                    <td>@Html.DisplayFor(modelItem => item.CompanyName)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablelist').DataTable({
                scrollX: true
            });
        });
    </script>
}