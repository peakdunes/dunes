@model DUNES.Shared.DTOs.WMS.WMSItemStatusReadDTO

@{
    ViewData["Title"] = "Delete Item Status";
}

<h6 class="text-danger mt-4">This action will permanently delete the record. This cannot be undone.</h6>

<div class="row">
    <div class="col-md-8">

        <dl class="row">
            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Id)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Id)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Name)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Name)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Active)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Active)</dd>
        </dl>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />

            <button type="submit" class="btn btn-outline-danger">Delete</button>
          
        </form>

    </div>
</div>
<div class="row">

    <div class="mt-2">
        <a asp-action="Index">Back to List</a>
    </div>
</div>